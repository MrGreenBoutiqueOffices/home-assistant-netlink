{
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]",
      "reconfigure_successful": "[%key:common::config_flow::abort::reconfigure_successful%]",
      "missing_host": "Cannot start OAuth flow without device host information.",
      "oauth_error": "[%key:common::config_flow::abort::oauth2_error%]",
      "oauth_failed": "[%key:common::config_flow::abort::oauth2_failed%]",
      "oauth_timeout": "[%key:common::config_flow::abort::oauth2_timeout%]",
      "user_rejected_authorize": "[%key:common::config_flow::abort::oauth2_user_rejected_authorize%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "flow_title": "{name}",
    "step": {
      "auth_method": {
        "title": "Choose authentication method",
        "description": "How do you want to authenticate?",
        "menu_options": {
          "oauth": "OAuth 2.0 (Recommended)",
          "manual": "Manual token entry"
        }
      },
      "user": {
        "title": "Setup NetLink",
        "description": "Enter the IP address of your NetLink device.",
        "data": {
          "host": "[%key:common::config_flow::data::host%]"
        },
        "data_description": {
          "host": "The IP address or hostname of your NetLink device."
        }
      },
      "manual": {
        "title": "Manual token entry",
        "description": "Enter your authentication token for {host}.",
        "data": {
          "token": "[%key:common::config_flow::data::token%]"
        },
        "data_description": {
          "token": "Find this token in the NetLink web interface settings."
        }
      },
      "discovery_confirm": {
        "title": "Configure device",
        "description": "We found {name} at {host}. Choose how you would like to authenticate.",
        "menu_options": {
          "oauth": "[%key:component::netlink::config::step::auth_method::menu_options::oauth%]",
          "discovery_manual": "[%key:component::netlink::config::step::auth_method::menu_options::manual%]"
        }
      },
      "discovery_manual": {
        "title": "[%key:component::netlink::config::step::discovery_confirm::title%]",
        "description": "Enter the authentication token for {name} at {host}.",
        "data": {
          "token": "[%key:common::config_flow::data::token%]"
        },
        "data_description": {
          "token": "[%key:component::netlink::config::step::manual::data_description::token%]"
        }
      },
      "reauth": {
        "title": "[%key:common::config_flow::title::reauth%]",
        "description": "The authentication for {host} needs to be renewed. Choose authentication method.",
        "menu_options": {
          "reauth_oauth": "[%key:component::netlink::config::step::auth_method::menu_options::oauth%]",
          "reauth_confirm": "[%key:component::netlink::config::step::auth_method::menu_options::manual%]"
        }
      },
      "reauth_confirm": {
        "title": "[%key:common::config_flow::title::reauth%]",
        "description": "The authentication token for {host} is no longer valid. Please enter a new token.",
        "data": {
          "token": "[%key:common::config_flow::data::token%]"
        }
      }
    }
  },
  "services": {
    "set_browser_url": {
      "name": "Set browser URL",
      "description": "Sets the browser URL on the NetLink Waveshare display.",
      "fields": {
        "url": {
          "name": "URL",
          "description": "The URL to load in the browser."
        }
      }
    }
  },
  "exceptions": {
    "auth_failed": {
      "message": "Authentication with {name} ({host}) failed. Please re-authenticate."
    },
    "cannot_connect": {
      "message": "Could not connect to {name} ({host}). Please check your network connection."
    },
    "command_failed": {
      "message": "The command could not be executed by {name}."
    },
    "command_unavailable": {
      "message": "The command could not be sent to {name}. The device may be offline or unreachable."
    }
  },
  "entity": {
    "sensor": {
      "browser_url": {
        "name": "Browser URL"
      },
      "desk_height": {
        "name": "Height"
      },
      "desk_mode": {
        "name": "Mode"
      },
      "desk_error": {
        "name": "Error"
      },
      "display_brightness": {
        "name": "Brightness"
      },
      "display_volume": {
        "name": "Volume"
      },
      "display_power": {
        "name": "Power"
      },
      "display_source": {
        "name": "Source"
      },
      "display_error": {
        "name": "Error"
      },
      "web_login_access_code": {
        "name": "Web login access code"
      },
      "web_login_access_code_valid_until": {
        "name": "Web login access code valid until"
      },
      "signing_maintenance_access_code": {
        "name": "Signing maintenance access code"
      },
      "signing_maintenance_access_code_valid_until": {
        "name": "Signing maintenance access code valid until"
      }
    },
    "number": {
      "desk_target_height": {
        "name": "Target height"
      },
      "display_brightness": {
        "name": "Brightness"
      },
      "display_volume": {
        "name": "Volume"
      }
    },
    "switch": {
      "desk_beep": {
        "name": "Beep"
      },
      "display_power": {
        "name": "Power"
      }
    },
    "select": {
      "display_source": {
        "name": "Source"
      }
    },
    "button": {
      "desk_stop": {
        "name": "Stop"
      },
      "desk_reset": {
        "name": "Reset"
      },
      "desk_calibrate": {
        "name": "Calibrate"
      },
      "browser_refresh": {
        "name": "Refresh"
      }
    },
    "binary_sensor": {
      "desk_moving": {
        "name": "Moving"
      }
    }
  }
}
